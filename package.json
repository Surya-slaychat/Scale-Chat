{
  "name": "scalechat",
  "private": true,
  "workspaces": [
    "my-app",
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "api:dev": "npm --workspace=apps/api run dev",
    "api:build": "npm --workspace=apps/api run build",
    "api:start": "npm --workspace=apps/api run start",
    "api:test:e2e": "npm --workspace=apps/api run test:e2e",
    "api:prisma": "npm --workspace=apps/api run prisma",
    "shared:build": "npm --workspace=packages/shared run build",
    "db:setup": "node scripts/setup-dev-db.mjs",
    "db:setup:dry": "node scripts/setup-dev-db.mjs --dry-run",
    "db:setup:first": "node scripts/setup-dev-db.mjs --create-containers",
    "postinstall": "node scripts/link-expo-router.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "version": "1.0.0",
  "dependencies": {
    "expo": "~56.0.4",
    "react": "19.2.3",
    "react-native": "0.85.3"
  }
}
